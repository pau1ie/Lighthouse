<!DOCTYPE html>
<html lang="en" dir="ltr" style="visibility: hidden;">
    <head>
        <%- include ("../partials/header.ejs") %>
    </head>
    <body>
        <%- include ("../partials/nav.ejs") %>
        <div id="wrapper">
            <% if (locals.messages.flash) { %>
                <div class="splash"><%- locals.messages.flash %></div>
            <% } %>
            <section>
                <h2>Edit Reply</h2>
                <form method="post">
                    <input type="hidden" name="threadid" value="<%= chosenReply.thread_id %>">
                    <label for="editor3">Reply Body</label>
                    <textarea id="editor3" name="editor3">
                        <%- chosenReply.body %>
                    </textarea><br>
                    <br><label for="replyauthor">Reply Author</label>
                    <select name="replyauthor" id="replyauthor" required>
                    </select>
                    <br><input type="submit" name="editreply" value="Edit Reply">
                </form>
                <script>ClassicEditor
                .create( document.querySelector( '#editor3' ), {
                    licenseKey: '',
                    fontColor: {
                            colors: [
                                {color: 'red',label: 'Red'},
                                {color: '#ff691f',label: 'Orange'},
                                { color: '#ffc20a',label: 'Yellow'},
                                {color: 'green',label: 'Green'},
                                {color: 'teal',label: 'Teal'},
                                {color: 'blue',label: 'Blue'},
                                {color: 'purple',label: 'Purple'},
                                {color: '#ff0f83',label: 'Pink'},
                                {color:'#663c28', label: 'Brown'}, 
                                {color: 'lightgray', label: 'Silver'}, 
                                {color: 'gray', label: 'Stone'}, 
                                {color: 'black', label: 'Black'}, 
                                {color: 'white', label: "White"}
                            ]
                        }
                } )
                .then( editor => {
                    window.editor = editor;
                } )
                .catch( error => {
                    console.error( 'Oops, something went wrong!' );
                    console.error( 'Please, report the following error on https://github.com/ckeditor/ckeditor5/issues with the build id and the error stack trace:' );
                    console.warn( 'Build id: 7x5cosrncqsm-gncdo1e4b9nh' );
                    console.error( error );
                } );
            </script>
            </form>
            </section>
    </div>
    <%- include ("../partials/footer.ejs") %>
    <script>
                async function getAlters(){
          let response = await fetch(`/system-data`, { 
    method: "GET",
                headers: { 
                  "api-lh-call": "api-lh-call",
                  'Content-Type': 'application/json',
                  "grab": "alters"
                } 
            });
            let body = await response.text();
            let sysInfo = JSON.parse(body);
            for (i in sysInfo.search){
            if ('<%- chosenReply.alt_id %>' == sysInfo.search[i].alt_id){
                  $("#replyauthor").append(`<option value="${sysInfo.search[i].alt_id}" selected>${sysInfo.search[i].name} (<%- capitalise(cookies.system_term) %>: ${sysInfo.search[i].sys_alias})</option>`);
            } else{
                $("#replyauthor").append(`<option value="${sysInfo.search[i].alt_id}">${sysInfo.search[i].name} (<%- capitalise(cookies.system_term) %>: ${sysInfo.search[i].sys_alias})</option>`);
            }
            }
        }
        getAlters();
    </script>
    </body>
</html>

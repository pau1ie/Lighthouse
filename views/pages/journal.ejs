<!DOCTYPE html>
<html lang="en" dir="ltr">

<head>
    <%- include ("../partials/header.ejs") %>
    <style>
        .textless{
          height: 1em;
          display: inline;
          font-size: 1.15em;
          padding: 0;
          vertical-align: text-top;
          background: transparent;
          color: var(--col5)
        }
      </style>
</head>

<body>
    <%- include ("../partials/nav.ejs") %>
    <div id="wrapper">
        <section>
            <% if (typeof splash == 'string'){  %>
                <p class="splash"><%- splash %></p>
            <% } %>
            <p><a href="/clearalter">Go back to the System page</a></p>
            <h2><%- Buffer.from(session.chosenAlter.name, 'base64').toString() %>'s Journal</h2>
            <sub>System: <%- Buffer.from(session.chosenAlter.sys_alias, 'base64').toString() %></sub>
            <form method="post">
                <h3>Create Journal Entry</h3>
                <label for="j_title">Journal title</label><br/>
                <input type="text" name="j_title" autocomplete="off" required><br/>
                <label for="j_body">Journal Body</label><br/>
                <textarea name="j_body" autocomplete="off" cols="60" rows="15" id="editor"></textarea><br/>
                <input type="submit" name="submit" value="Write post">
                <input type="reset" name="reset" value="Start Over">
                <script>ClassicEditor
                    .create( document.querySelector( '#editor' ), {
                        fontColor: {
        colors: [
            {color: 'red',label: 'Red'},{color: '#ff691f',label: 'Orange'},{ color: '#ffc20a',label: 'Yellow'},{color: 'green',label: 'Green'},{color: 'teal',label: 'Teal'},{color: 'blue',label: 'Blue'},{color: 'purple',label: 'Purple'},{color: '#ff0f83',label: 'Pink'},{color:'#663c28', label: 'Brown'}, {color: 'lightgray', label: 'Silver'}, {color: 'gray', label: 'Stone'}, {color: 'black', label: 'Black'}, {color: 'white', label: "White"}
        ]}
                    } )
                    .then( editor => {
                      window.editor = editor;
                    } )
                    .catch( error => {
                      console.error( 'Oops, something went wrong!' );
                      console.error( 'Please, report the following error on https://github.com/ckeditor/ckeditor5/issues with the build id and the error stack trace:' );
                      console.warn( 'Build id: c0gefhhqxz8y-2hxzvv2htugp' );
                      console.error( error );
                    } );
                </script>
            </form>
        </section>
        <hr/>
        <section>
            <section>
            <% for (i in session.journalPosts) { %>
                <article>
                <h2><%= session.journalPosts[i].title %></h2><a title="Edit <%= session.journalPosts[i].title %>" href="/journal/<%- session.journalPosts[i].p_id %>/edit"><i class="fa fa-pencil" aria-hidden="true"></i></a><form method="post" style="display: inline;"><button type="submit" name="<%- session.journalPosts[i].p_id %>" value="Remove" class="textless" onclick="deleteWarn('<%= session.journalPosts[i].title %>')"><span class="material-symbols-outlined textless"> delete</span></button></form>
                <p><sub>Posted <%= (session.journalPosts[i].created_on).toLocaleString(lang, { timeZone: Intl.DateTimeFormat().resolvedOptions().timeZone }) %></sub></p>
                <% var bodyArr= (session.journalPosts[i].body).replace(/\r/gi, '').split("\n").filter(function() { return true; });
                    for (j in bodyArr){
                        if (bodyArr[j] !== ''){ %>
                            <p><%- bodyArr[j] %></p>
                        <% }
                     }%>
            <!-- <p><a href="/journal/<%- session.journalPosts[i].p_id %>/edit" class="editbtn">Edit</a> <a href="/journal/<%- session.journalPosts[i].p_id %>/delete" class="deletebtn">Delete</a></p> -->
            </article>
            <% } %>
        </section>
        </section>
    </div>
    <%- include ("../partials/footer.ejs") %>
    <!-- <script>
        ClassicEditor
            .create( document.querySelector( '#editor' ) )
            .catch( error => {
                console.error( error );
            } );
    </script> -->
</body>
<script>
  const controller = new AbortController();
const { signal } = controller;

    function deleteWarn(title){
      if (confirm(`You're about to delete ${title}.\nAre you sure?`)){
        console.log("Delete Rule.");
      } else {
        event.preventDefault();
      }
    }

    signal.addEventListener("abort", () => {
  console.log(signal.aborted);
});

</script>

</html>

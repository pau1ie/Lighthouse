<!DOCTYPE html>
<html lang="en" dir="ltr">

<head>
    <%- include ("../partials/header.ejs") %>
</head>

<body>
    <%- include ("../partials/nav.ejs") %>
    <div id="wrapper">
        <section>
            <h2>Edit System- <%=  Buffer.from(alt.sys_alias, 'base64').toString() %></h2>
            <p>You can rename the system. Coming up: Move alters across systems.</p>
            <form method="post">
                <label for="sysname"><%=  Buffer.from(alt.sys_alias, 'base64').toString() %> will now be known as....</label>
                <input type="text" autocomplete="off" name="sysname" placeholder="Put a cool name here">
                <input type="submit" name="submit" value="Make it so">
            </form>
        </section>
    </div>
    <%- include ("../partials/footer.ejs") %>
</body>

</html>
